<?xml version="1.0" encoding="UTF-8"?>
<xliff version="1.2" xmlns="urn:oasis:names:tc:xliff:document:1.2">
    <file source-language="en" datatype="plaintext" original="messages">
        <body>
            <trans-unit id="banner.title">
                <source>Cookie Preferences</source>
            </trans-unit>
            <trans-unit id="banner.description">
                <source>We use cookies to improve your experience. You can choose which categories of cookies you allow. Essential cookies are always active as they are required for the website to function properly.</source>
            </trans-unit>
            <trans-unit id="banner.acceptAll">
                <source>Accept all</source>
            </trans-unit>
            <trans-unit id="banner.rejectAll">
                <source>Reject all</source>
            </trans-unit>
            <trans-unit id="banner.customize">
                <source>Customize</source>
            </trans-unit>
            <trans-unit id="modal.title">
                <source>Manage Cookie Preferences</source>
            </trans-unit>
            <trans-unit id="modal.intro">
                <source>Select which categories of cookies you consent to. Essential cookies cannot be disabled as they are required for the website to function.</source>
            </trans-unit>
            <trans-unit id="modal.close">
                <source>Close</source>
            </trans-unit>
            <trans-unit id="modal.savePreferences">
                <source>Save preferences</source>
            </trans-unit>
            <trans-unit id="modal.acceptAll">
                <source>Accept all</source>
            </trans-unit>
            <trans-unit id="modal.rejectAll">
                <source>Reject all</source>
            </trans-unit>
            <trans-unit id="modal.essential">
                <source>Essential</source>
            </trans-unit>
            <trans-unit id="placeholder.message">
                <source>This content requires your consent to be displayed.</source>
            </trans-unit>
            <trans-unit id="placeholder.openModal">
                <source>Manage cookie preferences</source>
            </trans-unit>
        </body>
    </file>
</xliff>
